{
  "$schema": "https://schema.tauri.app/config/2/capability",
  "identifier": "default",
  "description": "Default permissions for Stemgen GUI",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:window:allow-close",
    "core:window:allow-minimize",
    "core:window:allow-maximize",
    "core:window:allow-set-title",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",
    "dialog:allow-confirm",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-read-dir",
    "fs:allow-copy-file",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-stat",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$AUDIO/**" },
        { "path": "$APPDATA/**" },
        { "path": "$LOCALAPPDATA/**" },
        { "path": "$TEMP/**" }
      ]
    },
    "notification:default",
    "notification:allow-is-permission-granted",
    "notification:allow-request-permission",
    "notification:allow-notify",
    "os:default",
    "os:allow-platform",
    "os:allow-version",
    "os:allow-arch",
    "os:allow-family",
    "os:allow-locale",
    "process:default",
    "process:allow-exit",
    "process:allow-restart",
    "shell:default",
    "shell:allow-execute",
    "shell:allow-spawn",
    "shell:allow-open",
    "shell:allow-kill",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download-and-install",
    "window-state:default",
    "window-state:allow-restore-state",
    "window-state:allow-save-window-state"
  ]
}
